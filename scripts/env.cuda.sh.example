# Example — real file is generated by setup_cuda_env.sh (gitignored as scripts/env.cuda.sh)
export CUDA_HOME="/usr/lib/nvidia-cuda-toolkit"
export PATH="/usr/lib/nvidia-cuda-toolkit/bin:${PATH}"
export LD_LIBRARY_PATH="/usr/lib/nvidia-cuda-toolkit/lib64:${LD_LIBRARY_PATH:-}"
# Set to 1 only with a CUDA toolkit that matches your driver (not typical apt nvidia-cuda-toolkit on H200).
export VLLM_USE_FLASHINFER_SAMPLER=0
